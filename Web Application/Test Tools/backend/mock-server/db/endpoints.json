  {
    "id": "demoLgn1",
    "method": "POST",
    "path": "/demo/login",
    "description": "[Automation Demo] Authenticate a user. Valid password=P@ssw0rd",
    "collectionId": "demo0001",
    "defaultResponseLabel": "unauthorized",
    "rules": [
      {
        "id": "r-login-ok",
        "name": "Valid credentials",
        "active": true,
        "responseLabel": "success",
        "conditions": [
          {
            "source": "body",
            "field": "password",
            "operator": "eq",
            "value": "P@ssw0rd"
          },
          {
            "source": "body",
            "field": "username",
            "operator": "eq",
            "value": "alice"
          }
        ]
      }
    ],
    "responses": [
      {
        "label": "success",
        "status": 200,
        "delay": 0,
        "body": {
          "token": "mock-jwt-token-for-{{body.username}}",
          "user": {
            "username": "{{body.username}}",
            "role": "admin"
          }
        }
      },
      {
        "label": "unauthorized",
        "status": 401,
        "delay": 0,
        "body": {
          "error": "INVALID_CREDENTIALS",
          "message": "username or password is incorrect"
        }
      }
    ]
  },
  {
