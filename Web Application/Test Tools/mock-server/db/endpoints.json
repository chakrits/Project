  {
    "id": "ce80ec4b",
    "method": "GET",
    "path": "/api/test",
    "description": "Demo: query template + conditions",
    "responses": [
      {
        "label": "NamedGreeting",
        "status": 200,
        "delay": 0,
        "body": {
          "message": "Hello {{query.name}}"
        },
        "isDefault": false,
        "conditions": [
          {
            "source": "query",
            "field": "name",
            "operator": "exists"
          }
        ]
      },
      {
        "label": "Default",
        "status": 200,
        "delay": 0,
        "body": {
          "message": "Hello stranger"
        },
        "isDefault": true,
        "conditions": []
      }
    ]
  },
  {
    "id": "test-post-01",
    "method": "POST",
    "path": "/api/demo",
    "description": "Demo: body condition + body template",
    "responses": [
      {
        "label": "AdminWelcome",
        "status": 200,
        "delay": 0,
        "body": {
          "welcome": "Hello {{body.name}}",
          "role": "admin",
          "access": "full"
        },
        "isDefault": false,
        "conditions": [
          {
            "source": "body",
            "field": "role",
            "operator": "eq",
            "value": "admin"
          }
        ]
      },
      {
        "label": "GuestWelcome",
        "status": 200,
        "delay": 0,
        "body": {
          "welcome": "Hello {{body.name}}",
          "role": "guest",
          "access": "limited"
        },
        "isDefault": false,
        "conditions": [
          {
            "source": "body",
            "field": "role",
            "operator": "eq",
            "value": "guest"
          }
        ]
      },
      {
        "label": "BadRequest",
        "status": 400,
        "delay": 0,
        "body": {
          "error": "role is required (admin | guest)"
        },
        "isDefault": true,
        "conditions": []
      }
    ]
  },
  {
    "id": "test-put-01",
    "method": "PUT",
    "path": "/api/demo/:id",
    "description": "Demo: PUT with path param + body template",
    "responses": [
      {
        "label": "Updated",
        "status": 201,
        "delay": 0,
        "body": {
          "id": ":id",
          "updated": true,
          "name": "{{body.name}}",
          "lastname": "{{body.lastname}}"
        },
        "isDefault": false,
        "conditions": [
          {
            "source": "body",
            "field": "name",
            "operator": "exists",
            "value": "true"
          },
          {
            "source": "body",
            "field": "lastname",
            "operator": "exists",
            "value": ""
          },
          {
            "source": "params",
            "field": "id",
            "operator": "eq",
            "value": "1"
          }
        ]
      },
      {
        "label": "NotFound",
        "status": 404,
        "delay": 0,
        "body": {
          "error": "Record :id not found"
        },
        "isDefault": true,
        "conditions": []
      }
    ]
  },
  {
    "id": "test-patch-01",
    "method": "PATCH",
    "path": "/api/demo/:id",
    "description": "Demo: PATCH with header condition (auth)",
    "responses": [
      {
        "label": "Patched",
        "status": 200,
        "delay": 0,
        "body": {
          "id": ":id",
          "patched": true,
          "field": "{{body.field}}",
          "value": "{{body.value}}"
        },
        "isDefault": false,
        "conditions": [
          {
            "source": "header",
            "field": "authorization",
            "operator": "exists"
          }
        ]
      },
      {
        "label": "Unauthorized",
        "status": 401,
        "delay": 0,
        "body": {
          "error": "Authorization header required"
        },
        "isDefault": true,
        "conditions": []
      }
    ]
  },
